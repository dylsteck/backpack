{
	"$schema": "../gen/schemas/desktop-schema.json",
	"identifier": "main-capability",
	"description": "Capability for the main window",
	"windows": ["main"],
	"permissions": [
		"core:path:default",
		"core:event:default",
		"core:window:default",
		"core:app:default",
		"core:resources:default",
		"core:window:allow-set-title",
		"shell:default",
		"shell:allow-open",
		"shell:allow-execute",
		"dialog:default",
		"dialog:allow-open"
	]
}
