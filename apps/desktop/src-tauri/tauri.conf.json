{
	"$schema": "https://schema.tauri.app/config/2.0.0",
	"productName": "Cortex",
	"version": "0.0.0",
	"identifier": "app.cortex.desktop",
	"build": {
		"beforeDevCommand": "cd ../web && bun run dev",
		"devUrl": "http://localhost:5173",
		"beforeBuildCommand": "cd ../web && bun run build && cd ../server && bun run compile",
		"frontendDist": "../web/dist"
	},
	"app": {
		"withGlobalTauri": true,
		"security": {
			"csp": null
		}
	},
	"bundle": {
		"active": true,
		"targets": "all",
		"icon": ["icons/32x32.png", "icons/128x128.png"],
		"externalBin": ["../../server/server"]
	},
	"plugins": {}
}
