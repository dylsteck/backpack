{
  "name": "desktop",
  "productName": "Cortex",
  "version": "1.0.0",
  "description": "Cortex",
  "main": ".vite/build/main.js",
  "private": true,
  "scripts": {
    "dev": "electron-forge start",
    "dev:vanilla": "concurrently \"node esbuild.config.mjs --watch\" \"electron-forge start\"",
    "start": "electron-forge start",
    "build:vanilla": "node esbuild.config.mjs",
    "build:server": "bun run --cwd ../server compile",
    "build:all": "npm run build:vanilla && npm run build:server",
    "package": "electron-forge package",
    "package:full": "npm run build:all && electron-forge package",
    "make": "electron-forge make",
    "make:full": "npm run build:all && electron-forge make",
    "publish": "electron-forge publish",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "test:unit": "vitest",
    "test:e2e": "playwright test",
    "test:all": "vitest run && playwright test"
  },
  "author": "dylsteck",
  "devDependencies": {
    "@electron-forge/cli": "^7.10.2",
    "@electron-forge/maker-deb": "^7.10.2",
    "@electron-forge/maker-rpm": "^7.10.2",
    "@electron-forge/maker-squirrel": "^7.10.2",
    "@electron-forge/maker-zip": "^7.10.2",
    "@electron-forge/plugin-auto-unpack-natives": "^7.10.2",
    "@electron-forge/plugin-fuses": "^7.10.2",
    "@electron-forge/plugin-vite": "^7.10.2",
    "@electron-forge/shared-types": "^7.8.1",
    "@electron/fuses": "~1.8.0",
    "@eslint/compat": "^1.4.0",
    "@eslint/js": "^9.28.0",
    "@playwright/test": "^1.56.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron-squirrel-startup": "^1.0.2",
    "@types/eslint-config-prettier": "^6.11.3",
    "@types/node": "^24.7.2",
    "electron": "^38.3.0",
    "electron-devtools-installer": "^4.0.0",
    "electron-playwright-helpers": "^1.8.2",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9.38.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.4.0",
    "jsdom": "^27.0.1",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.7.0",
    "tailwindcss": "^4.1.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.1",
    "vite": "^7.1.11",
    "vitest": "^3.2.4",
    "esbuild": "^0.24.0",
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "@cortex/api": "workspace:*",
    "@tailwindcss/vite": "^4.1.14",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "better-sqlite3": "^12.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "tailwind-merge": "^3.3.1",
    "zod": "^4.1.12"
  }
}
