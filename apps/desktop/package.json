{
  "name": "desktop",
  "productName": "Cortex",
  "version": "1.0.0",
  "description": "Cortex Desktop App",
  "main": ".webpack/main",
  "scripts": {
    "dev": "concurrently --names \"NEXT,ELECTRON\" --prefix-colors \"cyan,magenta\" \"npm run dev:next\" \"npm run dev:electron\"",
    "dev:next": "next dev ./nextjs --port 3002",
    "dev:electron": "electron-forge start",
    "build": "npm run build:next && electron-forge make",
    "build:next": "next build ./nextjs",
    "start": "electron-forge start",
    "start:next": "next start ./nextjs --port 3002",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish"
  },
  "keywords": [],
  "author": {
    "name": "dylsteck",
    "email": "dylancsteck@gmail.com"
  },
  "license": "MIT",
  "dependencies": {
    "@cortex/api": "workspace:*",
    "@cortex/auth": "workspace:*",
    "@cortex/shared": "workspace:*",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-form": "^1.12.3",
    "@tanstack/react-query": "^5.85.5",
    "@trpc/client": "catalog:",
    "@trpc/server": "catalog:",
    "@trpc/tanstack-react-query": "^11.5.0",
    "better-auth": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-squirrel-startup": "^1.0.1",
    "lucide-react": "^0.548.0",
    "next": "15.5.4",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "sonner": "^2.0.5",
    "tailwind-merge": "^3.3.1",
    "zod": "catalog:"
