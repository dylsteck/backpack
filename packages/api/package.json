{
	"name": "@backpack/api",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./src/index.ts"
		},
		"./client": {
			"types": "./src/client.ts",
			"default": "./src/client.ts"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"default": "./src/*.ts"
		}
	},
	"type": "module",
	"scripts": {
		"build": "tsdown"
	},
	"devDependencies": {
		"tsdown": "catalog:"
	},
	"peerDependencies": {
		"typescript": "^5"
	},
	"dependencies": {
		"@backpack/db": "workspace:*",
		"@trpc/client": "catalog:",
		"@trpc/server": "catalog:",
		"dotenv": "catalog:",
		"drizzle-orm": "^0.44.7",
		"elysia": "catalog:",
		"zod": "catalog:"
	}
}
