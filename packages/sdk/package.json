{
	"name": "@backpack/sdk",
	"type": "module",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"require": "./dist/index.cjs"
		},
		"./*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js",
			"require": "./dist/*.cjs"
		}
	},
	"scripts": {
		"build": "tsdown",
		"check-types": "tsc --noEmit"
	},
	"dependencies": {
		"@backpack/db": "workspace:*",
		"drizzle-orm": "^0.44.2"
	},
	"devDependencies": {
		"@types/node": "^22.13.4",
		"tsdown": "catalog:",
		"typescript": "catalog:"
	},
	"peerDependencies": {
		"typescript": "^5"
	}
}
