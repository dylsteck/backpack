{
  "name": "cortex",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "elysia": "^1.3.21",
      "@trpc/server": "^11.5.0",
      "@trpc/client": "^11.5.0",
      "@trpc/react-query": "^11.5.0",
      "@tanstack/query-core": "^5.90.3",
      "better-auth": "^1.3.13",
      "dotenv": "^17.2.2",
      "zod": "^4.1.11",
      "typescript": "^5.8.2",
      "tsdown": "^0.15.5"
    }
  },
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:desktop": "turbo -F desktop dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @cortex/db db:push",
    "db:studio": "turbo -F @cortex/db db:studio",
    "db:generate": "turbo -F @cortex/db db:generate",
    "db:migrate": "turbo -F @cortex/db db:migrate"
