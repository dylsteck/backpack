{
  "name": "backpack",
  "private": true,
  "type": "module",
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "elysia": "^1.3.21",
      "dotenv": "^17.2.2",
      "zod": "^4.1.11",
      "typescript": "^5.8.2",
      "tsdown": "^0.15.5"
    }
  },
  "scripts": {
    "postinstall": "mkdir -p apps/desktop/node_modules && ln -sfn ../../../node_modules/electron apps/desktop/node_modules/electron && ln -sfn ../../../node_modules/better-sqlite3 apps/desktop/node_modules/better-sqlite3 && bunx --bun @electron/rebuild -f -w better-sqlite3 --project-root apps/desktop",
    "dev": "turbo -F @backpack/desktop start",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "lint": "turbo lint",
    "desktop": "turbo -F @backpack/desktop start",
    "db:push": "turbo -F @backpack/db db:push",
    "db:studio": "turbo -F @backpack/db db:studio",
    "db:generate": "turbo -F @backpack/db db:generate",
    "db:migrate": "turbo -F @backpack/db db:migrate"
  },
  "dependencies": {
    "dotenv": "^17.2.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@types/bun": "^1.2.6",
    "tsdown": "^0.15.5",
    "turbo": "^2.8.10"
  },
  "packageManager": "bun@1.3.4"
}
